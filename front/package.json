    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "26.1.0",
    "typescript": "^5.9.3",
    "vitest": "3.2.4"
